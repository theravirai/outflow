# Outflow Environment Variables
# Copy this file to '.env' and fill in YOUR database credentials

# Main database connection (for local development and production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/outflow

# Test database connection (used during pytest execution)
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/outflow_test

# Secret key for Flask session signing (Required for all environments)
SECRET_KEY=dev-secret-change-in-prod
